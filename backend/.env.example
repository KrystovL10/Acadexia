# ===========================================
# SHS Academic System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# Database connection URL (JDBC format)
DB_URL=jdbc:postgresql://localhost:5433/shs_academic

# Database username
DB_USERNAME=shs_admin

# Database password
DB_PASSWORD=change_me

# JWT secret key (minimum 256-bit / 32 characters)
# Generate with: openssl rand -base64 64
JWT_SECRET=change_me_generate_with_openssl_rand_base64_64

# JWT token expiration in milliseconds (default: 86400000 = 24 hours)
JWT_EXPIRATION=86400000

# Claude AI API key for AI-powered academic insights
# Obtain from: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# SMTP mail username (e.g., Gmail address for sending notifications)
MAIL_USERNAME=your_email@gmail.com

# SMTP mail password (use App Password if using Gmail with 2FA)
MAIL_PASSWORD=your_email_app_password

# Application environment: dev | prod
APP_ENV=dev
